{
  "name": "@eduadvisor/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../../.env ./node_modules/next/dist/bin/next dev --hostname 0.0.0.0 --port 3000",
    "dev:clean": "rm -rf .next && node --env-file=../../.env ./node_modules/next/dist/bin/next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "NODE_ENV=production next start",
    "lint": "next lint",
    "test": "playwright test --pass-with-no-tests"
  },
  "dependencies": {
    "@eduadvisor/shared": "workspace:*",
    "@tanstack/react-query": "^5.51.23",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
