# Core (required for non-local runtime)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=
ADMIN_API_KEY=
# Solo fallback local/dev para acceso admin (en producción se usa Google OAuth + allowlist)
ADMIN_CONSOLE_TOKEN=
ADMIN_ALLOWED_EMAILS=
ADMIN_AUTH_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_READ_API_KEY=
ADMIN_WRITE_API_KEY=
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000
PARENT_ALERT_SCORE_DELTA_THRESHOLD=4

# Database (required for non-local runtime)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/eduadvisor

# Cache
REDIS_URL=redis://localhost:6379

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey
MEILISEARCH_SCHOOLS_INDEX=schools
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# Storage (media de colegios premium)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=eduadvisor-school-media
MEDIA_UPLOAD_LOCAL_FALLBACK=true

# Auth (required for non-local runtime)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
AUTH_SESSION_SECRET=
AUTH_PARENT_ACCESS_CODE=
AUTH_SCHOOL_ACCESS_CODE=
AUTH_ALLOW_UNCLAIMED_SCHOOL_LOGIN=false
AUTH_SESSION_TTL_SECONDS=43200
AUTH_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
PUBLIC_FORM_CHALLENGE_REQUIRED=false
PUBLIC_FORM_CHALLENGE_PROVIDER=turnstile
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
LAUNCH_MODE=open
BETA_PRIVATE_MODE_ENABLED=false
BETA_PRIVATE_ALLOWED_PARENT_EMAILS=
BETA_PRIVATE_ALLOWED_SCHOOL_SLUGS=
BETA_PRIVATE_ALLOWED_SCHOOL_EMAILS=

# Analytics
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
WEB_VITAL_BUDGET_LCP_TARGET=2500
WEB_VITAL_BUDGET_LCP_MAX=4000
WEB_VITAL_BUDGET_CLS_TARGET=0.1
WEB_VITAL_BUDGET_CLS_MAX=0.25
WEB_VITAL_BUDGET_INP_TARGET=200
WEB_VITAL_BUDGET_INP_MAX=500
WEB_VITAL_BUDGET_FCP_TARGET=1800
WEB_VITAL_BUDGET_FCP_MAX=3000
WEB_VITAL_BUDGET_TTFB_TARGET=800
WEB_VITAL_BUDGET_TTFB_MAX=1800
WEB_VITAL_MIN_SAMPLES_FOR_BUDGET=20
PERF_ALERTS_ENABLED=true
PERF_ALERT_DEDUPE_WINDOW_MINUTES=360
PERF_ALERT_SLACK_WEBHOOK_URL=
PERF_ALERT_EMAIL_WEBHOOK_URL=
PERF_ALERT_EMAIL_TO=
PERF_ALERT_DISPATCH_FILE=/tmp/eduadvisor-performance-alert-dispatch.ndjson

# Billing (Sprint 24)
BILLING_WEBHOOK_SECRET=
BILLING_WEBHOOK_SECRET_STRIPE=
BILLING_WEBHOOK_SECRET_MERCADO_PAGO=
BILLING_WEBHOOK_MAX_AGE_SECONDS=300
BILLING_WEBHOOK_REPLAY_TTL_SECONDS=600
